---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>`,
    title: "Real-time Resource Monitoring",
    desc: "Track CPU, memory, and pod restarts with namespace-level granularity across all your clusters.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 001.357 2.059l.094.038a2.25 2.25 0 001.595-.107l.328-.137a3.75 3.75 0 012.659-.137l1.768.589M9.75 3.104A24.1 24.1 0 0112 3c.65 0 1.29.05 1.91.14M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Anomaly Detection",
    desc: "Z-score based analysis automatically flags unusual resource consumption before it escalates.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>`,
    title: "7-day CPU Forecasting",
    desc: "Predict future CPU usage so you can plan capacity and avoid surprise bills.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>`,
    title: "Multi-cluster Support",
    desc: "Monitor all clusters from a single Grafana dashboard. Multiple instances, one shared view.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>`,
    title: "Webhook Notifications",
    desc: "Push alerts and weekly cost summaries to Slack, Microsoft Teams, or any HTTP endpoint.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: "Offline Licensing",
    desc: "RSA-based license validation with no external server. Your data never leaves your infrastructure.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    title: "Zero-config Setup",
    desc: "Works with minikube, Docker Desktop, and standard clusters. One installer script handles everything.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/></svg>`,
    title: "Prometheus + Grafana",
    desc: "Exposes a Prometheus metrics endpoint and auto-imports a pre-built Grafana dashboard.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Cost Tracking",
    desc: "Understand exactly what each namespace and workload costs — broken down and ready to act on.",
  },
];

const freeFeatures = ["1 cluster", "Up to 4 namespaces", "30-day data retention", "Grafana dashboard", "Prometheus exporter"];
const proFeatures = ["Unlimited clusters", "Unlimited namespaces", "365-day retention", "Multi-cluster dashboard", "Webhook notifications", "Weekly cost summaries", "Anomaly detection", "7-day CPU forecasting"];
---

<Layout
  title="KubePocket — Kubernetes Cost & Resource Monitor"
  description="Lightweight Kubernetes monitoring that tracks resource usage, detects anomalies, and surfaces cloud costs — all in one Grafana dashboard."
>
  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4 bg-gray-950/80 backdrop-blur-md border-b border-white/5">
    <span class="text-lg font-bold tracking-tight">
      Kube<span class="text-blue-400">Pocket</span>
    </span>
    <div class="hidden sm:flex items-center gap-8 text-sm text-gray-400">
      <a href="#features" class="hover:text-white transition-colors">Features</a>
      <a href="#pricing" class="hover:text-white transition-colors">Pricing</a>
    </div>
    <a
      href="https://github.com/yunusolgun/kubepocket"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-lg border border-white/10 hover:border-white/25 transition-colors text-gray-300 hover:text-white"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
      GitHub
    </a>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-24 pb-16 overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-blue-600/10 rounded-full blur-3xl"></div>
      <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] bg-violet-600/8 rounded-full blur-3xl"></div>
    </div>

    <div class="mb-6 inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-white/5 text-gray-300 border border-white/10">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
      Lightweight · Zero-config · Open source
    </div>

    <h1 class="text-5xl sm:text-7xl font-extrabold leading-[1.05] tracking-tight max-w-4xl bg-gradient-to-b from-white to-gray-400 bg-clip-text text-transparent">
      Kubernetes costs,<br/>finally <span class="text-blue-400 bg-none [-webkit-text-fill-color:rgb(96,165,250)]">under control.</span>
    </h1>

    <p class="mt-7 text-lg sm:text-xl text-gray-400 max-w-2xl leading-relaxed">
      KubePocket tracks CPU, memory, pod restarts, and cloud costs across your clusters —
      with anomaly detection, 7-day forecasting, and Grafana dashboards out of the box.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center gap-3">
      <a
        href="https://github.com/yunusolgun/kubepocket"
        target="_blank"
        rel="noopener noreferrer"
        class="group w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-blue-500 hover:bg-blue-400 font-semibold transition-colors text-sm"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        View on GitHub
      </a>
      <a
        href="#features"
        class="w-full sm:w-auto px-6 py-3 rounded-xl border border-white/10 hover:border-white/25 font-semibold transition-colors text-sm text-gray-300 hover:text-white"
      >
        See Features →
      </a>
    </div>

    <!-- Stats row -->
    <div class="mt-20 flex flex-wrap justify-center gap-x-12 gap-y-6">
      {[
        { value: "9+", label: "Core features" },
        { value: "3", label: "Notification channels" },
        { value: "7-day", label: "CPU forecasting" },
        { value: "1-cmd", label: "Install" },
      ].map((s) => (
        <div class="text-center">
          <div class="text-2xl font-bold text-white">{s.value}</div>
          <div class="text-xs text-gray-500 mt-0.5">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Features</p>
        <h2 class="text-3xl sm:text-5xl font-bold mb-5">Everything you need,<br class="hidden sm:block"/> nothing you don't.</h2>
        <p class="text-gray-400 max-w-lg mx-auto text-lg">
          From real-time metrics to weekly cost summaries — full visibility without the complexity.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {features.map((f) => (
          <div class="group p-6 rounded-2xl bg-white/[0.03] border border-white/[0.06] hover:bg-white/[0.06] hover:border-blue-500/20 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mb-4 text-blue-400 group-hover:bg-blue-500/20 transition-colors" set:html={f.icon} />
            <h3 class="font-semibold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE STRIP -->
  <section class="py-16 px-6 border-y border-white/5 bg-white/[0.02]">
    <div class="max-w-4xl mx-auto">
      <p class="text-center text-xs font-semibold text-gray-500 uppercase tracking-widest mb-10">How it works</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-0 text-sm text-gray-300">
        {[
          { label: "Collector", sub: "Gathers K8s data" },
          { label: "PostgreSQL", sub: "Stores metrics" },
          { label: "REST API", sub: "Port 8000" },
          { label: "Prometheus", sub: "Port 8001" },
          { label: "Grafana", sub: "Single dashboard" },
        ].map((step, i) => (
          <div class="flex sm:flex-col items-center gap-2 sm:gap-0">
            <div class="px-4 py-3 rounded-xl bg-white/5 border border-white/8 text-center min-w-[120px]">
              <div class="font-semibold text-white">{step.label}</div>
              <div class="text-xs text-gray-500 mt-0.5">{step.sub}</div>
            </div>
            {i < 4 && (
              <div class="text-gray-600 sm:hidden">↓</div>
              <div class="text-gray-600 hidden sm:block mx-2">→</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="py-28 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Pricing</p>
        <h2 class="text-3xl sm:text-5xl font-bold mb-5">Start free, scale when ready.</h2>
        <p class="text-gray-400 max-w-md mx-auto text-lg">No credit card required to get started.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <!-- Free -->
        <div class="p-8 rounded-2xl bg-white/[0.03] border border-white/[0.08] flex flex-col">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Free</div>
          <div class="flex items-end gap-1 mb-1">
            <span class="text-5xl font-extrabold">$0</span>
          </div>
          <div class="text-sm text-gray-500 mb-8">forever</div>
          <ul class="space-y-3 flex-1">
            {freeFeatures.map((item) => (
              <li class="flex items-center gap-3 text-sm text-gray-300">
                <svg class="w-4 h-4 text-blue-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="https://github.com/yunusolgun/kubepocket"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 block text-center px-4 py-3 rounded-xl border border-white/10 hover:border-white/25 text-sm font-semibold transition-colors text-gray-300 hover:text-white"
          >
            Get Started
          </a>
        </div>

        <!-- Pro -->
        <div class="relative p-8 rounded-2xl bg-gradient-to-b from-blue-500/15 to-blue-600/5 border border-blue-500/25 flex flex-col">
          <div class="absolute top-5 right-5 text-xs font-semibold px-2.5 py-1 rounded-full bg-blue-500 text-white">Popular</div>
          <div class="text-xs font-semibold text-blue-400 uppercase tracking-widest mb-4">Pro</div>
          <div class="flex items-end gap-1 mb-1">
            <span class="text-5xl font-extrabold">$99</span>
            <span class="text-gray-400 mb-1.5">/yr</span>
          </div>
          <div class="text-sm text-gray-500 mb-8">or $12/month · per cluster</div>
          <ul class="space-y-3 flex-1">
            {proFeatures.map((item) => (
              <li class="flex items-center gap-3 text-sm text-gray-300">
                <svg class="w-4 h-4 text-blue-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="https://github.com/yunusolgun/kubepocket"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 block text-center px-4 py-3 rounded-xl bg-blue-500 hover:bg-blue-400 text-sm font-semibold transition-colors"
          >
            Get Started
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-white/5 py-10 px-6">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-base font-bold tracking-tight">
        Kube<span class="text-blue-400">Pocket</span>
      </span>
      <p class="text-sm text-gray-500">© 2025 KubePocket. Kubernetes cost & resource monitoring, simplified.</p>
      <a
        href="https://github.com/yunusolgun/kubepocket"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-gray-500 hover:text-white transition-colors flex items-center gap-1.5"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        GitHub
      </a>
    </div>
  </footer>
</Layout>
