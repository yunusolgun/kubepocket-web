---
import Layout from '../layouts/Layout.astro';

const previews = [
  { file: "/screenshots/preview-1-overview.png",   label: "Namespace Overview",    desc: "CPU, memory, restarts and anomaly scores per namespace — at a glance." },
  { file: "/screenshots/preview-3-cost.png",        label: "Cost Analysis",         desc: "See exactly which namespaces are consuming your cluster budget." },
  { file: "/screenshots/preview-4-waste.png",       label: "Waste Detection",       desc: "Surface over-provisioned pods and reclaim wasted CPU & memory." },
  { file: "/screenshots/preview-5-podanomaly.png",  label: "Pod Anomaly",           desc: "Rank pods by anomaly score, restart rate, and CPU spikes." },
  { file: "/screenshots/preview-7-events.png",      label: "Kubernetes Events",     desc: "Track OOMKilled, CrashLoopBackOff, and FailedScheduling in real time." },
  { file: "/screenshots/preview-9-nodes.png",       label: "Node Capacity",         desc: "Allocatable vs. requested vs. actual usage — per node." },
  { file: "/screenshots/preview-11-storage.png",    label: "PVC & Storage",         desc: "Bound/unbound PVCs, capacity, and active storage alerts." },
  { file: "/screenshots/preview-2-recomendations.png", label: "Recommendations",   desc: "Actionable fixes for crashing pods and anomalous workloads." },
];

const freeFeatures  = ["1 cluster", "Up to 4 namespaces", "30-day retention", "Grafana dashboard", "Prometheus exporter"];
const proFeatures   = ["Unlimited clusters", "Unlimited namespaces", "365-day retention", "Multi-cluster view", "Webhook alerts", "Weekly cost reports", "Anomaly detection", "7-day CPU forecast"];
---

<Layout
  title="KubePocket — Kubernetes Cost & Resource Monitor"
  description="Track CPU, memory, costs and anomalies across your Kubernetes clusters — with a pre-built Grafana dashboard and zero configuration."
>

<!-- ── NAV ── -->
<header class="fixed inset-x-0 top-0 z-50 flex items-center justify-between px-6 py-4 bg-[#0a0a0f]/80 backdrop-blur border-b border-white/5">
  <a href="/" class="text-base font-bold tracking-tight">Kube<span class="text-blue-400">Pocket</span></a>
  <nav class="hidden md:flex items-center gap-8 text-sm text-gray-400">
    <a href="#previews" class="hover:text-white transition-colors">Screenshots</a>
    <a href="#features" class="hover:text-white transition-colors">Features</a>
    <a href="#pricing"  class="hover:text-white transition-colors">Pricing</a>
  </nav>
  <a href="https://github.com/yunusolgun/kubepocket" target="_blank" rel="noopener noreferrer"
     class="flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-lg border border-white/10 hover:border-white/25 text-gray-300 hover:text-white transition-colors">
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
    GitHub
  </a>
</header>

<!-- ── HERO ── -->
<section class="relative flex flex-col items-center text-center px-6 pt-40 pb-20 overflow-hidden">
  <!-- ambient glows -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[900px] h-[600px] rounded-full bg-blue-600/10 blur-[120px]"></div>
    <div class="absolute top-1/2 left-1/4  w-[500px] h-[500px] rounded-full bg-violet-700/6 blur-[100px]"></div>
  </div>

  <div class="mb-5 inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-white/5 text-gray-400 border border-white/10">
    <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
    Open source · Zero-config · Self-hosted
  </div>

  <h1 class="text-5xl sm:text-[4.5rem] font-extrabold leading-[1.05] tracking-tight max-w-4xl">
    <span class="hero-gradient-text">Kubernetes cost &amp; resource<br/>monitoring</span>
    <span class="text-blue-400"> — simplified.</span>
  </h1>

  <p class="mt-6 text-lg text-gray-400 max-w-2xl leading-relaxed">
    A lightweight Grafana dashboard that surfaces CPU waste, memory anomalies, pod crashes,
    and cloud costs across all your clusters. One install script, no external servers.
  </p>

  <div class="mt-9 flex flex-wrap justify-center gap-3">
    <a href="https://github.com/yunusolgun/kubepocket" target="_blank" rel="noopener noreferrer"
       class="flex items-center gap-2 px-6 py-3 rounded-xl bg-blue-500 hover:bg-blue-400 font-semibold text-sm transition-colors">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
      View on GitHub
    </a>
    <a href="#previews"
       class="px-6 py-3 rounded-xl border border-white/10 hover:border-white/25 font-semibold text-sm text-gray-300 hover:text-white transition-colors">
      See Screenshots ↓
    </a>
  </div>

  <!-- Hero screenshot -->
  <div class="mt-16 w-full max-w-5xl rounded-2xl overflow-hidden border border-white/10 shadow-[0_0_80px_rgba(59,130,246,0.12)] ring-1 ring-white/5">
    <div class="flex items-center gap-1.5 px-4 py-3 bg-white/5 border-b border-white/8">
      <span class="w-3 h-3 rounded-full bg-white/10"></span>
      <span class="w-3 h-3 rounded-full bg-white/10"></span>
      <span class="w-3 h-3 rounded-full bg-white/10"></span>
      <span class="ml-3 text-xs text-gray-500 font-mono">Grafana · KubePocket Dashboard</span>
    </div>
    <img src="/screenshots/preview-1-overview.png" alt="KubePocket Namespace Overview" class="w-full" loading="eager" />
  </div>
</section>

<!-- ── SCREENSHOT CAROUSEL ── -->
<section id="previews" class="py-28 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Screenshots</p>
      <h2 class="text-3xl sm:text-5xl font-bold mb-4">Built for every corner of your cluster.</h2>
      <p class="text-gray-400 max-w-lg mx-auto text-base">8 dashboard sections — each focused on a specific operational question.</p>
    </div>

    <!-- Tab labels -->
    <div class="flex flex-wrap justify-center gap-2 mb-8" id="slider-tabs">
      {previews.map((p, i) => (
        <button
          data-index={i}
          class={`slider-tab px-3 py-1.5 rounded-lg text-xs font-medium transition-all ${i === 0 ? 'bg-blue-500 text-white' : 'bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white'}`}
        >
          {p.label}
        </button>
      ))}
    </div>

    <!-- Slide window -->
    <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-[0_0_60px_rgba(59,130,246,0.1)]">
      <!-- Browser bar -->
      <div class="flex items-center gap-1.5 px-4 py-3 bg-[#111118] border-b border-white/8">
        <span class="w-3 h-3 rounded-full bg-white/10 block"></span>
        <span class="w-3 h-3 rounded-full bg-white/10 block"></span>
        <span class="w-3 h-3 rounded-full bg-white/10 block"></span>
        <span class="ml-3 text-xs text-gray-500" style="font-family: 'JetBrains Mono', 'Fira Code', monospace;" id="slider-url">Grafana · Namespace Overview</span>
      </div>

      <!-- Images -->
      <div class="relative overflow-hidden bg-[#111118]" style="aspect-ratio: 16/9;">
        {previews.map((p, i) => (
          <img
            src={p.file}
            alt={p.label}
            data-slide={i}
            class={`slide-img absolute inset-0 w-full h-full object-cover transition-opacity duration-400 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        ))}

        <!-- Prev / Next -->
        <button id="slide-prev" aria-label="Previous" class="absolute left-3 top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center rounded-full bg-black/50 hover:bg-black/70 border border-white/10 text-white transition-colors z-10">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button id="slide-next" aria-label="Next" class="absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center rounded-full bg-black/50 hover:bg-black/70 border border-white/10 text-white transition-colors z-10">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>

      <!-- Caption + dots -->
      <div class="flex items-center justify-between px-5 py-4 bg-[#111118] border-t border-white/8">
        <p class="text-sm text-gray-400" id="slider-desc">{previews[0].desc}</p>
        <div class="flex items-center gap-1.5 shrink-0 ml-4" id="slider-dots">
          {previews.map((_, i) => (
            <button
              data-dot={i}
              aria-label={`Slide ${i + 1}`}
              class={`dot-btn rounded-full transition-all ${i === 0 ? 'w-4 h-1.5 bg-blue-400' : 'w-1.5 h-1.5 bg-white/20 hover:bg-white/40'}`}
            ></button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── FEATURES ── -->
<section id="features" class="py-24 px-6 border-t border-white/5">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Features</p>
      <h2 class="text-3xl sm:text-5xl font-bold mb-5">Everything you need,<br class="hidden sm:block"/> nothing you don't.</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        { title: "Real-time Metrics",       desc: "CPU, memory, and pod restarts tracked per namespace with live Grafana graphs." },
        { title: "Anomaly Detection",       desc: "Z-score analysis flags unusual consumption before it turns into an incident." },
        { title: "7-day CPU Forecast",      desc: "Predictive trending so you can plan capacity before you run out." },
        { title: "Cost Attribution",        desc: "Relative cost share per namespace with time-series breakdowns." },
        { title: "Waste Detection",         desc: "Idle and over-provisioned pods ranked by wasted CPU & memory cores." },
        { title: "Multi-cluster Support",   desc: "Multiple collector instances, one shared Grafana dashboard." },
        { title: "Webhook Notifications",   desc: "Push alerts and weekly summaries to Slack, Teams, or any HTTP endpoint." },
        { title: "Offline Licensing",       desc: "RSA-based validation — no external servers. Data stays on your infra." },
        { title: "One-command Install",     desc: "Automated script handles Docker builds, Helm deploy, and dashboard import." },
      ].map((f) => (
        <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/[0.07] hover:bg-white/[0.06] hover:border-blue-500/20 transition-all">
          <h3 class="font-semibold text-white mb-2 text-sm">{f.title}</h3>
          <p class="text-xs text-gray-500 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── PRICING ── -->
<section id="pricing" class="py-28 px-6 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Pricing</p>
      <h2 class="text-3xl sm:text-5xl font-bold mb-5">Start free, scale when ready.</h2>
      <p class="text-gray-400 max-w-sm mx-auto text-lg">No credit card required.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
      <!-- Free -->
      <div class="p-8 rounded-2xl bg-white/[0.03] border border-white/[0.08] flex flex-col">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Free</p>
        <div class="flex items-end gap-1 mb-1">
          <span class="text-5xl font-extrabold text-white">$0</span>
        </div>
        <p class="text-sm text-gray-500 mb-8">forever</p>
        <ul class="space-y-3 flex-1">
          {freeFeatures.map((item) => (
            <li class="flex items-center gap-3 text-sm text-gray-300">
              <svg class="w-4 h-4 text-blue-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="https://github.com/yunusolgun/kubepocket" target="_blank" rel="noopener noreferrer"
           class="mt-8 block text-center px-4 py-3 rounded-xl border border-white/10 hover:border-white/25 text-sm font-semibold text-gray-300 hover:text-white transition-colors">
          Get Started
        </a>
      </div>

      <!-- Pro -->
      <div class="relative p-8 rounded-2xl bg-gradient-to-b from-blue-500/15 to-transparent border border-blue-500/25 flex flex-col">
        <span class="absolute top-5 right-5 text-xs font-semibold px-2.5 py-1 rounded-full bg-blue-500 text-white">Popular</span>
        <p class="text-xs font-semibold text-blue-400 uppercase tracking-widest mb-4">Pro</p>
        <div class="flex items-end gap-1 mb-1">
          <span class="text-5xl font-extrabold text-white">$99</span>
          <span class="text-gray-400 mb-1.5 text-base">/yr</span>
        </div>
        <p class="text-sm text-gray-500 mb-8">or $12 / month · per cluster</p>
        <ul class="space-y-3 flex-1">
          {proFeatures.map((item) => (
            <li class="flex items-center gap-3 text-sm text-gray-300">
              <svg class="w-4 h-4 text-blue-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="https://github.com/yunusolgun/kubepocket" target="_blank" rel="noopener noreferrer"
           class="mt-8 block text-center px-4 py-3 rounded-xl bg-blue-500 hover:bg-blue-400 text-sm font-semibold transition-colors">
          Get Started
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ── FOOTER ── -->
<footer class="border-t border-white/5 py-10 px-6">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
    <span class="text-base font-bold text-white tracking-tight">Kube<span class="text-blue-400">Pocket</span></span>
    <p>© 2025 KubePocket · Kubernetes cost & resource monitoring, simplified.</p>
    <a href="https://github.com/yunusolgun/kubepocket" target="_blank" rel="noopener noreferrer"
       class="flex items-center gap-1.5 hover:text-white transition-colors">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
      GitHub
    </a>
  </div>
</footer>

<style>
  .hero-gradient-text {
    background: linear-gradient(to bottom, #ffffff, #9ca3af);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

<script>
  const previews = [
    { label: "Namespace Overview",  url: "Grafana · Namespace Overview",  desc: "CPU, memory, restarts and anomaly scores per namespace — at a glance." },
    { label: "Cost Analysis",       url: "Grafana · Cost Analysis",        desc: "See exactly which namespaces are consuming your cluster budget." },
    { label: "Waste Detection",     url: "Grafana · Waste Detection",      desc: "Surface over-provisioned pods and reclaim wasted CPU & memory." },
    { label: "Pod Anomaly",         url: "Grafana · Pod Anomaly",          desc: "Rank pods by anomaly score, restart rate, and CPU spikes." },
    { label: "Kubernetes Events",   url: "Grafana · Kubernetes Events",    desc: "Track OOMKilled, CrashLoopBackOff, and FailedScheduling in real time." },
    { label: "Node Capacity",       url: "Grafana · Node Capacity",        desc: "Allocatable vs. requested vs. actual usage — per node." },
    { label: "PVC & Storage",       url: "Grafana · PVC & Storage",        desc: "Bound/unbound PVCs, capacity, and active storage alerts." },
    { label: "Recommendations",     url: "Grafana · Recommendations",      desc: "Actionable fixes for crashing pods and anomalous workloads." },
  ];

  let current = 0;

  const imgs   = document.querySelectorAll<HTMLImageElement>('.slide-img');
  const tabs   = document.querySelectorAll<HTMLButtonElement>('.slider-tab');
  const dots   = document.querySelectorAll<HTMLButtonElement>('.dot-btn');
  const desc   = document.getElementById('slider-desc')!;
  const urlEl  = document.getElementById('slider-url')!;
  const prev   = document.getElementById('slide-prev')!;
  const next   = document.getElementById('slide-next')!;

  function goTo(n: number) {
    imgs[current].classList.replace('opacity-100', 'opacity-0');
    tabs[current].classList.remove('bg-blue-500', 'text-white');
    tabs[current].classList.add('bg-white/5', 'text-gray-400');
    dots[current].classList.remove('w-4', 'h-1.5', 'bg-blue-400');
    dots[current].classList.add('w-1.5', 'h-1.5', 'bg-white/20');

    current = (n + previews.length) % previews.length;

    imgs[current].classList.replace('opacity-0', 'opacity-100');
    tabs[current].classList.remove('bg-white/5', 'text-gray-400');
    tabs[current].classList.add('bg-blue-500', 'text-white');
    dots[current].classList.remove('w-1.5', 'h-1.5', 'bg-white/20');
    dots[current].classList.add('w-4', 'h-1.5', 'bg-blue-400');

    desc.textContent  = previews[current].desc;
    urlEl.textContent = previews[current].url;
  }

  prev.addEventListener('click', () => goTo(current - 1));
  next.addEventListener('click', () => goTo(current + 1));
  tabs.forEach((tab) => tab.addEventListener('click', () => goTo(Number(tab.dataset.index))));
  dots.forEach((dot) => dot.addEventListener('click', () => goTo(Number(dot.dataset.dot))));

  // auto-advance every 5s
  let timer = setInterval(() => goTo(current + 1), 5000);
  document.getElementById('previews')!.addEventListener('mouseenter', () => clearInterval(timer));
  document.getElementById('previews')!.addEventListener('mouseleave', () => {
    timer = setInterval(() => goTo(current + 1), 5000);
  });
</script>
</Layout>
