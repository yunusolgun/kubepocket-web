---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4 bg-gray-950/80 backdrop-blur-md border-b border-white/5">
    <span class="text-lg font-bold tracking-tight">
      Kube<span class="text-blue-400">Pocket</span>
    </span>
    <a
      href="#waitlist"
      class="text-sm font-medium px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-400 transition-colors"
    >
      Join Waitlist
    </a>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-6 pt-24 pb-16">
    <!-- Badge -->
    <div class="mb-6 inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
      Coming soon — join the waitlist
    </div>

    <!-- Headline -->
    <h1 class="text-4xl sm:text-6xl font-extrabold leading-tight tracking-tight max-w-3xl">
      Kubernetes, in your&nbsp;<span class="text-blue-400">pocket</span>.
    </h1>

    <!-- Sub -->
    <p class="mt-6 text-lg sm:text-xl text-gray-400 max-w-xl leading-relaxed">
      Monitor pods, namespaces, and deployments from your phone.
      Real-time visibility and control — no laptop required.
    </p>

    <!-- CTA -->
    <div class="mt-10 flex flex-col sm:flex-row items-center gap-3">
      <a
        href="#waitlist"
        class="w-full sm:w-auto px-6 py-3 rounded-xl bg-blue-500 hover:bg-blue-400 font-semibold transition-colors text-sm"
      >
        Get Early Access
      </a>
      <a
        href="#features"
        class="w-full sm:w-auto px-6 py-3 rounded-xl border border-white/10 hover:border-white/25 font-semibold transition-colors text-sm text-gray-300"
      >
        See Features
      </a>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">Everything you need, on the go</h2>
      <p class="text-gray-400 text-center mb-16 max-w-lg mx-auto">
        KubePocket brings your cluster dashboard to iOS and Android — built for engineers who can't always be at their desk.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            icon: "📦",
            title: "Pod Management",
            desc: "View running pods, check logs, and restart workloads directly from the app.",
          },
          {
            icon: "⚡",
            title: "Real-time Events",
            desc: "Stream cluster events as they happen. Catch issues before they become incidents.",
          },
          {
            icon: "🌐",
            title: "Multi-cluster",
            desc: "Switch between multiple clusters and contexts with a single tap.",
          },
          {
            icon: "🔔",
            title: "Smart Alerts",
            desc: "Get notified when pods crash, nodes become unhealthy, or deployments fail.",
          },
          {
            icon: "🔒",
            title: "Secure by Default",
            desc: "kubeconfig stays on your device. Nothing is sent to third-party servers.",
          },
          {
            icon: "📊",
            title: "Resource Metrics",
            desc: "CPU and memory usage at a glance for nodes, pods, and namespaces.",
          },
        ].map((f) => (
          <div class="p-6 rounded-2xl bg-white/5 border border-white/8 hover:border-blue-500/30 transition-colors">
            <div class="text-2xl mb-3">{f.icon}</div>
            <h3 class="font-semibold mb-2">{f.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WAITLIST -->
  <section id="waitlist" class="py-24 px-6">
    <div class="max-w-lg mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">Be the first to know</h2>
      <p class="text-gray-400 mb-10">
        KubePocket is in private beta. Drop your email and we'll let you in early.
      </p>

      <form
        class="flex flex-col sm:flex-row gap-3"
        onsubmit="handleSubmit(event)"
      >
        <input
          id="email-input"
          type="email"
          required
          placeholder="you@example.com"
          class="flex-1 px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:border-blue-500 focus:outline-none text-sm placeholder-gray-500 transition-colors"
        />
        <button
          type="submit"
          class="px-6 py-3 rounded-xl bg-blue-500 hover:bg-blue-400 font-semibold text-sm transition-colors whitespace-nowrap"
        >
          Notify Me
        </button>
      </form>
      <p id="form-message" class="mt-4 text-sm text-green-400 hidden">
        You're on the list! We'll be in touch.
      </p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-white/5 py-8 px-6 text-center text-sm text-gray-500">
    <p>© 2025 KubePocket. Built with ❤️ for Kubernetes engineers.</p>
  </footer>
</Layout>

<script>
  function handleSubmit(e: Event) {
    e.preventDefault();
    const input = document.getElementById("email-input") as HTMLInputElement;
    const msg = document.getElementById("form-message") as HTMLElement;
    if (input.value) {
      input.value = "";
      msg.classList.remove("hidden");
    }
  }
  (window as any).handleSubmit = handleSubmit;
</script>
