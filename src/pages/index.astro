<script>
  const previews = [
    { url: "Grafana · Namespace Overview", desc: "CPU, memory, restarts and anomaly scores per namespace — at a glance." },
    { url: "Grafana · Cost Analysis",      desc: "See exactly which namespaces are consuming your cluster budget." },
    { url: "Grafana · Waste Detection",    desc: "Surface over-provisioned pods and reclaim wasted CPU & memory." },
    { url: "Grafana · Pod Anomaly",        desc: "Rank pods by anomaly score, restart rate, and CPU spikes." },
    { url: "Grafana · Kubernetes Events",  desc: "Track OOMKilled, CrashLoopBackOff, and FailedScheduling in real time." },
    { url: "Grafana · Node Capacity",      desc: "Allocatable vs. requested vs. actual usage per node." },
    { url: "Grafana · PVC & Storage",      desc: "Bound/unbound PVCs, capacity, and active storage alerts." },
    { url: "Grafana · Recommendations",    desc: "Actionable fixes for crashing pods and anomalous workloads." },
  ];

  let current = 0;
  const imgs  = Array.from(document.querySelectorAll<HTMLImageElement>('.slide-img'));
  const tabs  = Array.from(document.querySelectorAll<HTMLButtonElement>('.slider-tab'));
  const dots  = Array.from(document.querySelectorAll<HTMLButtonElement>('.dot-btn'));
  const desc  = document.getElementById('slider-desc')!;
  const urlEl = document.getElementById('slider-url')!;

  function goTo(n: number) {
    // deactivate current
    imgs[current].style.opacity = '0';
    tabs[current].style.background = 'rgba(255,255,255,0.05)';
    tabs[current].style.color = '#9ca3af';
    dots[current].style.width = '6px';
    dots[current].style.height = '6px';
    dots[current].style.background = 'rgba(255,255,255,0.2)';

    current = (n + previews.length) % previews.length;

    // activate new
    imgs[current].style.opacity = '1';
    tabs[current].style.background = '#3b82f6';
    tabs[current].style.color = '#fff';
    dots[current].style.width = '16px';
    dots[current].style.height = '6px';
    dots[current].style.background = '#60a5fa';

    desc.textContent  = previews[current].desc;
    urlEl.textContent = previews[current].url;
  }

  document.getElementById('slide-prev')!.addEventListener('click', () => goTo(current - 1));
  document.getElementById('slide-next')!.addEventListener('click', () => goTo(current + 1));
  tabs.forEach(tab => tab.addEventListener('click', () => goTo(Number(tab.dataset.index))));
  dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.dot))));

  let timer = setInterval(() => goTo(current + 1), 5000);
  const section = document.getElementById('previews')!;
  section.addEventListener('mouseenter', () => clearInterval(timer));
  section.addEventListener('mouseleave', () => { timer = setInterval(() => goTo(current + 1), 5000); });
</script>

