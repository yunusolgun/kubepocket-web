---
import Layout from '../layouts/Layout.astro';

const GITHUB = "https://github.com/yunusolgun/kubepocket";

const previews = [
  { file: "/screenshots/preview-1-overview.png",      label: "Namespace Overview", desc: "CPU, memory, restarts and anomaly scores per namespace — at a glance." },
  { file: "/screenshots/preview-3-cost.png",           label: "Cost Analysis",      desc: "See exactly which namespaces are consuming your cluster budget." },
  { file: "/screenshots/preview-4-waste.png",          label: "Waste Detection",    desc: "Surface over-provisioned pods and reclaim wasted CPU & memory." },
  { file: "/screenshots/preview-5-podanomaly.png",     label: "Pod Anomaly",        desc: "Rank pods by anomaly score, restart rate, and CPU spikes." },
  { file: "/screenshots/preview-7-events.png",         label: "K8s Events",         desc: "Track OOMKilled, CrashLoopBackOff, and FailedScheduling in real time." },
  { file: "/screenshots/preview-9-nodes.png",          label: "Node Capacity",      desc: "Allocatable vs. requested vs. actual usage per node." },
  { file: "/screenshots/preview-11-storage.png",       label: "PVC & Storage",      desc: "Bound/unbound PVCs, capacity, and active storage alerts." },
  { file: "/screenshots/preview-2-recomendations.png", label: "Recommendations",    desc: "Actionable fixes for crashing pods and anomalous workloads." },
];

const tableRows = [
  { feature: "Clusters",              free: "1",        pro: "Unlimited" },
  { feature: "Namespaces",            free: "Up to 4",  pro: "Unlimited" },
  { feature: "Data retention",        free: "30 days",  pro: "365 days"  },
  { feature: "Grafana dashboard",     free: true,       pro: true        },
  { feature: "Prometheus exporter",   free: true,       pro: true        },
  { feature: "Real-time metrics",     free: true,       pro: true        },
  { feature: "Multi-cluster view",    free: false,      pro: true        },
  { feature: "Anomaly detection",     free: false,      pro: true        },
  { feature: "7-day CPU forecast",    free: false,      pro: true        },
  { feature: "Waste detection",       free: false,      pro: true        },
  { feature: "Webhook notifications", free: false,      pro: true        },
  { feature: "Weekly cost reports",   free: false,      pro: true        },
  { feature: "Offline licensing",     free: true,       pro: true        },
];
---

<Layout
  title="KubePocket — Kubernetes Cost & Resource Monitor"
  description="Track CPU, memory, costs and anomalies across your Kubernetes clusters — with a pre-built Grafana dashboard and zero configuration."
>

<style>
  /* ── DARK (default) ── */
  :root {
    --bg:           #0a0a0f;
    --nav-bg:       rgba(10,10,15,0.85);
    --text:         #ffffff;
    --text-muted:   #94a3b8;
    --text-subtle:  #6b7280;
    --border:       rgba(255,255,255,0.08);
    --border-soft:  rgba(255,255,255,0.06);
    --card-bg:      rgba(255,255,255,0.02);
    --card-hover:   rgba(255,255,255,0.04);
    --browser-bg:   #111118;
    --badge-bg:     rgba(255,255,255,0.04);
    --badge-border: rgba(255,255,255,0.10);
    --btn-ghost:    rgba(255,255,255,0.12);
    --btn-ghost-text: #d1d5db;
    --tab-inactive: rgba(255,255,255,0.05);
    --tab-inactive-text: #9ca3af;
    --dot-inactive: rgba(255,255,255,0.2);
    --table-alt:    rgba(255,255,255,0.01);
    --pro-card-bg:  linear-gradient(160deg, rgba(59,130,246,0.12), rgba(59,130,246,0.03));
    --pro-border:   rgba(59,130,246,0.30);
    --check-muted:  rgba(255,255,255,0.18);
  }

  /* ── LIGHT ── */
  [data-theme="light"] {
    --bg:           #f8fafc;
    --nav-bg:       rgba(248,250,252,0.90);
    --text:         #0f172a;
    --text-muted:   #475569;
    --text-subtle:  #64748b;
    --border:       rgba(0,0,0,0.08);
    --border-soft:  rgba(0,0,0,0.06);
    --card-bg:      #ffffff;
    --card-hover:   #f1f5f9;
    --browser-bg:   #f1f5f9;
    --badge-bg:     rgba(0,0,0,0.04);
    --badge-border: rgba(0,0,0,0.08);
    --btn-ghost:    rgba(0,0,0,0.08);
    --btn-ghost-text: #374151;
    --tab-inactive: rgba(0,0,0,0.05);
    --tab-inactive-text: #64748b;
    --dot-inactive: rgba(0,0,0,0.18);
    --table-alt:    rgba(0,0,0,0.015);
    --pro-card-bg:  linear-gradient(160deg, rgba(59,130,246,0.08), rgba(59,130,246,0.02));
    --pro-border:   rgba(59,130,246,0.25);
    --check-muted:  rgba(0,0,0,0.18);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    transition: background 0.2s, color 0.2s;
  }

  a { text-decoration: none; }

  /* theme toggle */
  .theme-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text-subtle);
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.15s;
  }
  .theme-btn:hover   { background: var(--card-bg); color: var(--text); }
  .theme-btn.active  { background: var(--card-bg); border-color: var(--border); color: var(--text); }

  /* nav links */
  .nav-link { color: var(--text-muted); font-size: 14px; transition: color 0.15s; }
  .nav-link:hover { color: var(--text); }

  /* ghost button */
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 16px; border-radius: 8px;
    border: 1px solid var(--btn-ghost);
    color: var(--btn-ghost-text); font-size: 14px; font-weight: 500;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--text-muted); color: var(--text); }

  .btn-secondary {
    display: inline-flex; align-items: center;
    padding: 12px 24px; border-radius: 12px;
    border: 1px solid var(--btn-ghost);
    color: var(--btn-ghost-text); font-size: 14px; font-weight: 600;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-secondary:hover { border-color: var(--text-muted); color: var(--text); }

  /* section label */
  .section-label {
    font-size: 12px; font-weight: 600; color: #60a5fa;
    letter-spacing: 0.1em; text-transform: uppercase;
    display: block; margin-bottom: 12px;
  }

  /* section heading */
  .section-heading {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 800; letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.1;
  }

  /* section sub */
  .section-sub { font-size: 16px; color: var(--text-muted); max-width: 480px; margin: 16px auto 0; line-height: 1.6; }

  /* cards */
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    transition: background 0.15s, border-color 0.15s;
  }

  /* slider tab */
  .slider-tab {
    padding: 6px 14px; border-radius: 8px;
    font-size: 12px; font-weight: 500;
    border: none; cursor: pointer; transition: all 0.2s;
    background: var(--tab-inactive);
    color: var(--tab-inactive-text);
  }
  .slider-tab.active { background: #3b82f6; color: #fff; }

  /* dot */
  .dot-btn {
    border: none; cursor: pointer; border-radius: 999px; transition: all 0.2s;
    width: 6px; height: 6px;
    background: var(--dot-inactive);
  }
  .dot-btn.active { width: 16px; height: 6px; background: #60a5fa; }

  /* browser bar */
  .browser-bar {
    display: flex; align-items: center; gap: 6px;
    padding: 12px 16px;
    background: var(--browser-bg);
    border-bottom: 1px solid var(--border);
  }
  .browser-dot {
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--border); display: block;
  }

  /* free card border button */
  .btn-free {
    display: block; text-align: center;
    padding: 12px; border-radius: 10px;
    border: 1px solid var(--border);
    color: var(--btn-ghost-text); font-size: 14px; font-weight: 600;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-free:hover { border-color: var(--text-muted); color: var(--text); }

  /* footer */
  footer { border-top: 1px solid var(--border-soft); padding: 40px 24px; }
</style>

<!-- NAV -->
<header style="position:fixed;top:0;left:0;right:0;z-index:50;display:flex;align-items:center;justify-content:space-between;padding:14px 24px;background:var(--nav-bg);backdrop-filter:blur(12px);border-bottom:1px solid var(--border-soft);">
  <a href="/" style="font-size:16px;font-weight:700;letter-spacing:-0.02em;color:var(--text);">Kube<span style="color:#60a5fa;">Pocket</span></a>

  <nav style="display:flex;align-items:center;gap:28px;">
    <a href="#previews" class="nav-link">Screenshots</a>
    <a href="#features" class="nav-link">Features</a>
    <a href="#pricing"  class="nav-link">Pricing</a>
  </nav>

  <div style="display:flex;align-items:center;gap:8px;">
    <!-- Theme toggle -->
    <div style="display:flex;align-items:center;gap:2px;padding:3px;border-radius:10px;border:1px solid var(--border);background:var(--card-bg);">
      <button class="theme-btn active" data-mode="auto"  title="Auto"  id="btn-auto">A</button>
      <button class="theme-btn"        data-mode="light" title="Light" id="btn-light">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block;">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
      </button>
      <button class="theme-btn"        data-mode="dark"  title="Dark"  id="btn-dark">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block;">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>
    </div>
    <a href={GITHUB} target="_blank" rel="noopener noreferrer" class="btn-ghost">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display:block;flex-shrink:0;">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      GitHub
    </a>
  </div>
</header>

<!-- HERO -->
<section style="display:flex;flex-direction:column;align-items:center;text-align:center;padding:160px 24px 80px;">
  <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;font-size:12px;font-weight:500;background:var(--badge-bg);border:1px solid var(--badge-border);color:var(--text-muted);margin-bottom:24px;">
    <span style="width:6px;height:6px;border-radius:50%;background:#4ade80;display:inline-block;"></span>
    Open source · Zero-config · Self-hosted
  </div>

  <h1 style="font-size:clamp(2.5rem,6vw,4.5rem);font-weight:900;line-height:1.05;letter-spacing:-0.03em;max-width:900px;color:var(--text);margin-bottom:24px;">
    Kubernetes cost &amp; resource monitoring
    <span style="color:#60a5fa;"> — simplified.</span>
  </h1>

  <p style="font-size:18px;color:var(--text-muted);max-width:640px;line-height:1.7;margin-bottom:36px;">
    A lightweight Grafana dashboard that surfaces CPU waste, memory anomalies, pod crashes,
    and cloud costs across all your clusters. One install script, no external servers.
  </p>

  <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:12px;margin-bottom:64px;">
    <a href={GITHUB} target="_blank" rel="noopener noreferrer"
       style="display:inline-flex;align-items:center;gap:8px;padding:12px 24px;border-radius:12px;background:#3b82f6;color:#fff;font-size:14px;font-weight:600;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display:block;flex-shrink:0;">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      View on GitHub
    </a>
    <a href="#previews" class="btn-secondary">See Screenshots ↓</a>
  </div>

  <!-- Hero image -->
  <div class="card" style="width:100%;max-width:1000px;overflow:hidden;box-shadow:0 0 0 1px var(--border);">
    <div class="browser-bar">
      <span class="browser-dot"></span>
      <span class="browser-dot"></span>
      <span class="browser-dot"></span>
      <span style="margin-left:10px;font-size:12px;color:var(--text-subtle);font-family:monospace;">Grafana · KubePocket Dashboard</span>
    </div>
    <img src="/screenshots/preview-1-overview.png" alt="KubePocket Namespace Overview" style="width:100%;display:block;" loading="eager" />
  </div>
</section>

<!-- CAROUSEL -->
<section id="previews" style="padding:112px 24px;">
  <div style="max-width:960px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <span class="section-label">Screenshots</span>
      <h2 class="section-heading">Built for every corner of your cluster.</h2>
      <p class="section-sub">8 dashboard sections — each focused on a specific operational question.</p>
    </div>

    <div id="slider-tabs" style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:24px;">
      {previews.map((p, i) => (
        <button data-index={i} class={`slider-tab${i === 0 ? ' active' : ''}`}>{p.label}</button>
      ))}
    </div>

    <div class="card" style="overflow:hidden;">
      <div class="browser-bar">
        <span class="browser-dot"></span>
        <span class="browser-dot"></span>
        <span class="browser-dot"></span>
        <span id="slider-url" style="margin-left:10px;font-size:12px;color:var(--text-subtle);font-family:monospace;">Grafana · Namespace Overview</span>
      </div>

      <div style="position:relative;background:var(--browser-bg);aspect-ratio:16/9;">
        {previews.map((p, i) => (
          <img src={p.file} alt={p.label} data-slide={i} class="slide-img"
            style={`position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:opacity 0.4s;opacity:${i === 0 ? 1 : 0};`}
            loading={i === 0 ? 'eager' : 'lazy'} />
        ))}

        <button id="slide-prev" aria-label="Previous"
          style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:rgba(0,0,0,0.45);border:1px solid rgba(255,255,255,0.15);color:#fff;cursor:pointer;z-index:10;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:block;"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button id="slide-next" aria-label="Next"
          style="position:absolute;right:12px;top:50%;transform:translateY(-50%);width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:rgba(0,0,0,0.45);border:1px solid rgba(255,255,255,0.15);color:#fff;cursor:pointer;z-index:10;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:block;"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;background:var(--browser-bg);border-top:1px solid var(--border);">
        <p id="slider-desc" style="font-size:14px;color:var(--text-muted);">{previews[0].desc}</p>
        <div id="slider-dots" style="display:flex;align-items:center;gap:6px;flex-shrink:0;margin-left:16px;">
          {previews.map((_, i) => (
            <button data-dot={i} aria-label={`Slide ${i + 1}`} class={`dot-btn${i === 0 ? ' active' : ''}`}></button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES TABLE -->
<section id="features" style="padding:112px 24px;border-top:1px solid var(--border-soft);">
  <div style="max-width:760px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <span class="section-label">Features</span>
      <h2 class="section-heading">Free vs Pro</h2>
      <p class="section-sub">Everything included, broken down by plan.</p>
    </div>

    <div class="card" style="overflow:hidden;">
      <div style="display:grid;grid-template-columns:1fr 120px 120px;background:var(--card-bg);border-bottom:1px solid var(--border);">
        <div style="padding:14px 20px;font-size:12px;font-weight:600;color:var(--text-subtle);text-transform:uppercase;letter-spacing:0.05em;">Feature</div>
        <div style="padding:14px 20px;font-size:12px;font-weight:600;color:var(--text-subtle);text-transform:uppercase;letter-spacing:0.05em;text-align:center;">Free</div>
        <div style="padding:14px 20px;font-size:12px;font-weight:600;color:#60a5fa;text-transform:uppercase;letter-spacing:0.05em;text-align:center;">Pro</div>
      </div>

      {tableRows.map((row, i) => (
        <div style={`display:grid;grid-template-columns:1fr 120px 120px;border-bottom:1px solid var(--border);${i % 2 === 1 ? 'background:var(--table-alt);' : ''}`}>
          <div style="padding:13px 20px;font-size:14px;color:var(--text);">{row.feature}</div>
          <div style="padding:13px 20px;text-align:center;font-size:14px;display:flex;align-items:center;justify-content:center;">
            {typeof row.free === 'boolean'
              ? row.free
                ? <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;"><path d="M4.5 12.75l6 6 9-13.5"/></svg>
                : <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--check-muted)" stroke-width="2" stroke-linecap="round" style="display:inline-block;"><path d="M18 6L6 18M6 6l12 12"/></svg>
              : <span style="color:var(--text-muted);">{row.free}</span>
            }
          </div>
          <div style="padding:13px 20px;text-align:center;font-size:14px;display:flex;align-items:center;justify-content:center;">
            {typeof row.pro === 'boolean'
              ? row.pro
                ? <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;"><path d="M4.5 12.75l6 6 9-13.5"/></svg>
                : <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--check-muted)" stroke-width="2" stroke-linecap="round" style="display:inline-block;"><path d="M18 6L6 18M6 6l12 12"/></svg>
              : <span style="color:var(--text);font-weight:500;">{row.pro}</span>
            }
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" style="padding:112px 24px;border-top:1px solid var(--border-soft);">
  <div style="max-width:720px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <span class="section-label">Pricing</span>
      <h2 class="section-heading">Start free, scale when ready.</h2>
      <p class="section-sub">No credit card required.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
      <!-- Free -->
      <div class="card" style="padding:32px;display:flex;flex-direction:column;">
        <p style="font-size:11px;font-weight:600;color:var(--text-subtle);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:16px;">Free</p>
        <p style="font-size:48px;font-weight:900;letter-spacing:-0.03em;color:var(--text);margin-bottom:4px;">$0</p>
        <p style="font-size:14px;color:var(--text-subtle);margin-bottom:32px;">forever</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:12px;flex:1;margin-bottom:32px;">
          {["1 cluster", "Up to 4 namespaces", "30-day retention", "Grafana dashboard", "Prometheus exporter"].map(item => (
